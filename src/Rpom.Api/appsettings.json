{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=rpom;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Jwt": {
    "Issuer": "rpom-api",
    "Audience": "rpom-clients",
    "Secret": "REPLACE_ME_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG",
    "AccessTokenMinutes": 720,
    "RefreshTokenDays": 30
  },
  "Bootstrap": {
    "OwnerUsername": "owner",
    "OwnerPassword": "ChangeMe@2026",
    "OwnerFullName": "Restaurant Owner (Bootstrap)",
    "OwnerEmail": null,
    "OwnerPhone": null
  },
  "Rpom": {
    "Outbox": {
      "IntervalInSeconds": 10,
      "BatchSize": 20
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Quartz": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
